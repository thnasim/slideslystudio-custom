# Sanity — get these from sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Server-only token for draft/preview reads (Editor permissions)
SANITY_API_READ_TOKEN=your_read_token

# Used by /api/draft route to enable preview mode
SANITY_PREVIEW_SECRET=any_random_string_you_choose

# Public site URL (used for absolute URLs, OG, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
